{
  "name": "pss-swim-school",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:fresh": "npx --yes kill-port 3000 && next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "preview": "next dev -p 3000",
    "preview:prod": "next build && npx --yes kill-port 3000 && next start -p 3000",
    "preview:only": "npx --yes kill-port 3000 && next start -p 3000",
    "build:node20": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-with-node20.ps1 npm run build",
    "preview:node20": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-with-node20.ps1 npm run preview",
    "preview:prod:node20": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-with-node20.ps1 npm run preview:prod",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.14",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.0.14",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
