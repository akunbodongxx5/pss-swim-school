# Lokal (SQLite): relatif ke folder prisma/
DATABASE_URL="file:../dev.db"

# Vercel + Neon Postgres: set di Project → Environment Variables (bukan SQLite).
# Disarankan URL dengan pooling, contoh suffix: ?sslmode=require&pgbouncer=true&connect_timeout=15
# Setelah deploy pertama: jalankan dari mesin lokal dengan DATABASE_URL prod:
#   npx prisma db push
# agar tabel (termasuk SchoolBranding) ada di database production.

# PIN untuk login admin (default: 1234)
ADMIN_PIN="1234"

# Hanya jika deploy HTTPS sendiri (bukan Vercel): agar cookie peran terkirim ke API
# COOKIE_SECURE=true
