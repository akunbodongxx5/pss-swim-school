# Lokal (SQLite): relatif ke folder prisma/
DATABASE_URL="file:../dev.db"

# Vercel + Neon Postgres: set di Project → Environment Variables (bukan SQLite).
#
# Penting: di dashboard Neon pakai connection string **Pooled** / **Transaction mode**
# (bukan hanya Direct) untuk app Next.js — host biasanya berisi "-pooler".
# Contoh suffix: ?sslmode=require&pgbouncer=true&connect_timeout=15
#
# Kalau sering error "Server has closed the connection", ganti ke URL pooler
# atau pastikan tidak ada proses lain yang mematikan koneksi DB.
#
# Setelah deploy pertama: dari mesin lokal dengan DATABASE_URL prod:
#   npx prisma db push

# PIN untuk login admin (default: 1234)
ADMIN_PIN="1234"

# Hanya jika deploy HTTPS sendiri (bukan Vercel): agar cookie peran terkirim ke API
# COOKIE_SECURE=true

# Warna latar ikon PWA (persegi) saat logo di-"pad", format #rrggbb — default abu sangat muda
# PWA_ICON_BACKGROUND=#f8fafc
