generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Satu baris global (id = 1): nama & logo sekolah untuk white-label.
model SchoolBranding {
  id          Int     @id @default(1)
  schoolName  String  @default("Swim School")
  logoDataUrl String? @db.Text
  logoVersion Int     @default(1)

  swimLevels     SwimLevel[]
  sessionBundles SessionBundleDefinition[]
}

/// Level renang per sekolah (urutan & nama bebas, maks. 20 per sekolah — ditegakkan di API).
model SwimLevel {
  id        String @id @default(cuid())
  schoolId  Int    @default(1)
  sortOrder Int
  name      String

  school   SchoolBranding @relation(fields: [schoolId], references: [id])
  students Student[]

  @@unique([schoolId, sortOrder])
  @@index([schoolId])
}

/// Bundle kelas: level mana saja + aturan lintasan & kapasitas (dapat dikustom per sekolah).
model SessionBundleDefinition {
  id        String @id @default(cuid())
  schoolId  Int    @default(1)
  /// Kunci stabil untuk seed/migrasi, mis. MIXED_1_3
  slug      String
  name      String
  sortOrder Int
  /// JSON array id SwimLevel, mis. ["clxxx","clyyy"]
  levelIds  String @db.Text
  /// JSON array lintasan diizinkan, mis. [1] atau [2,3,4]
  allowedLanesJson String @db.Text

  maxStudents1Coach Int
  maxStudents2Coach Int
  /// null = tidak ada aturan khusus; mis. 2 = maks 2 kelas bundle ini di line 1 pada jam sama
  maxConcurrentSessionsOnLane1 Int?

  school   SchoolBranding @relation(fields: [schoolId], references: [id])
  sessions ScheduledSession[]

  @@unique([schoolId, slug])
  @@index([schoolId])
}

model Coach {
  id   String @id @default(cuid())
  name String
  /// JSON array id SwimLevel (lead).
  teachLevels String @default("[]")
  /// JSON array id SwimLevel (trainee / pelatih kedua saja).
  traineeLevels String @default("[]")

  sessionsPrimary   ScheduledSession[] @relation("CoachPrimary")
  sessionsSecondary ScheduledSession[] @relation("CoachSecondary")
}

model Student {
  id        String    @id @default(cuid())
  name      String
  levelId   String
  swimLevel SwimLevel @relation(fields: [levelId], references: [id], onDelete: Restrict)

  enrollments Enrollment[]
  conflictsA  ConflictPair[] @relation("ConflictA")
  conflictsB  ConflictPair[] @relation("ConflictB")
  waitlist    WaitlistEntry[]
}

model ConflictPair {
  id         String  @id @default(cuid())
  studentAId String
  studentBId String
  studentA   Student @relation("ConflictA", fields: [studentAId], references: [id], onDelete: Cascade)
  studentB   Student @relation("ConflictB", fields: [studentBId], references: [id], onDelete: Cascade)

  @@unique([studentAId, studentBId])
}

model ScheduledSession {
  id             String                  @id @default(cuid())
  date           DateTime
  hour           Int
  lane           Int
  bundleId       String
  bundle         SessionBundleDefinition @relation(fields: [bundleId], references: [id], onDelete: Restrict)
  coachPrimaryId String
  coachSecondaryId String?
  coachPrimary     Coach   @relation("CoachPrimary", fields: [coachPrimaryId], references: [id])
  coachSecondary   Coach?  @relation("CoachSecondary", fields: [coachSecondaryId], references: [id])
  enrollments      Enrollment[]

  @@index([bundleId])
}

model Enrollment {
  id                 String           @id @default(cuid())
  scheduledSessionId String
  studentId          String
  student            Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session            ScheduledSession @relation(fields: [scheduledSessionId], references: [id], onDelete: Cascade)

  @@unique([scheduledSessionId, studentId])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  note      String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model ScheduleMonthConfig {
  id           String @id @default(cuid())
  year         Int
  month        Int
  openTailDays String @default("[]")

  @@unique([year, month])
}
